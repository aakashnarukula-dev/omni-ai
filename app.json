{
  "expo": {
    "name": "Omni",
    "slug": "omni",
    "scheme": "omni",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0b"
    },
    "ios": {
      "bundleIdentifier": "com.aakash.omni",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Omni listens to your voice to sort tasks, alarms, and notes.",
        "NSCameraUsageDescription": "Omni uses the camera to capture cards and IDs for secure storage.",
        "NSFaceIDUsageDescription": "Omni uses Face ID to unlock the app so only you can view your cards and IDs."
      }
    },
    "android": {
      "package": "com.aakash.omni",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "com.android.alarm.permission.SET_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#fafafa",
          "defaultChannel": "omni"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Omni uses Face ID to unlock the app so only you can view your cards and IDs."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Omni listens to your voice to sort tasks, alarms, and notes.",
          "speechRecognitionPermission": "Omni uses speech recognition to transcribe what you say into tasks and notes.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23f8f9b1-5a4c-4a42-88e0-60fc255e04eb"
      }
    },
    "owner": "aakashnarukula"
  }
}
